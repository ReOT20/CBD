# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Build and packaging artifacts
build/
dist/
site/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.tox/
.nox/

# Coverage outputs
.coverage
.coverage.*
htmlcov/
coverage.xml

# Local environment files
.env
.env.*
*.local

# Editor and OS files
.DS_Store
Thumbs.db
.idea/
.vscode/

# Project-local agent metadata
.codex
.codex/
.opencode
.opencode/
.claude
.claude/
.kilo
.kilo/
.roo
.roo/
.roocode
.roocode/
.continue
.continue/

# Local runtime workspace
data/*
!data/.gitkeep
!data/raw/
!data/interim/
!data/cache/
data/raw/*
!data/raw/.gitkeep
data/interim/*
!data/interim/.gitkeep
data/cache/*
!data/cache/.gitkeep
outputs/*
!outputs/.gitkeep
